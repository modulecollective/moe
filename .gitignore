# Binaries
/moe
/cmd/moe/moe
*.exe

# Test / coverage artifacts
*.test
*.out
coverage.*

# Editor / OS cruft
.DS_Store
.idea/
.vscode/
*.swp

# Agent / dev-env runtime drop sites — .moe/ from moe's dev-env,
# .claude from the Claude Code harness (sandbox write tracking,
# settings, and materialized skills). .claude is matched without a
# trailing slash for the same device-vs-directory reason as below.
.moe/
.claude

# Agent run artifacts — written into the repo root by the MoE
# workflow; not part of the published surface.
.moe-run/
.moe-canvas.md

# Sandbox runtime bind-mounts. fly.io / similar runtimes shadow host
# config files at the cwd / writable-add-dir scope by bind-mounting
# /dev/null as character devices with these basenames. They aren't
# agent edits — the agent can't even remove them ("Device or resource
# busy") — but `git status` reports them as untracked because the
# basename exists on disk, which trips push pre-flight's "uncommitted
# files" gate. Matched without trailing slash so the pattern catches
# both the device (file) and a real directory if one ever shows up.
.bash_profile
.bashrc
.gitconfig
.gitmodules
.idea
.mcp.json
.profile
.ripgreprc
.vscode
.zprofile
.zshrc
